<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a8a"/>
      <stop offset="100%" style="stop-color:#2563eb"/>
    </linearGradient>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FFD700"/>
      <stop offset="50%" style="stop-color:#FFFACD"/>
      <stop offset="100%" style="stop-color:#DAA520"/>
    </linearGradient>
  </defs>
  
  <!-- Background with rounded corners -->
  <rect width="512" height="512" rx="100" fill="url(#bgGrad)"/>
  
  <!-- Trumpet Icon -->
  <g transform="translate(140, 120) scale(10)">
    <path d="M11 5L6 9H3v6h3l5 4V5z" fill="url(#goldGrad)"/>
    <path d="M15.54 8.46a5 5 0 0 1 0 7.07" stroke="url(#goldGrad)" stroke-width="2" stroke-linecap="round" fill="none"/>
    <path d="M19.07 4.93a10 10 0 0 1 0 14.14" stroke="url(#goldGrad)" stroke-width="2" stroke-linecap="round" fill="none"/>
  </g>
  
  <!-- Text -->
  <text x="256" y="400" text-anchor="middle" font-family="Georgia, serif" font-size="52" font-weight="bold" fill="url(#goldGrad)">TRUMPETER</text>
  <text x="256" y="450" text-anchor="middle" font-family="Georgia, serif" font-size="36" font-weight="bold" fill="#FFFACD" letter-spacing="10">TV</text>
</svg>
